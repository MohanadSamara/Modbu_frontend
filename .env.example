# Backend Oracle Connection
# Edit .env with your values, then cp .env.example .env
# NEVER put real passwords in this file — it is committed to a public repo.

ORACLE_USER=your_db_user
ORACLE_PASSWORD=your_db_password
ORACLE_HOST=localhost
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=XEPDB1

# Backend port
PORT=3000

# ── Frontend (Vite) ────────────────────────────────────────────────
# Power BI report to embed on the Fuel Levels page. Paste the URL from
# Power BI → File → Embed report → "Publish to web" (public) or
# "Website or portal" (secure). Must be an EMBED url, not a share link.
# Leave blank to show the "connect a report" placeholder instead.
VITE_POWERBI_URL=
